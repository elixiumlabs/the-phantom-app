# ----- Client (Vite) -----
# Firebase web config (public — these are safe to ship to the browser)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ----- Server (Cloud Functions secrets — set with `firebase functions:secrets:set`) -----
# DO NOT prefix with VITE_. These never reach the browser.
# ANTHROPIC_API_KEY     — Phantom AI generators (Claude)
# STRIPE_SECRET_KEY     — billing
# STRIPE_WEBHOOK_SECRET — webhook signature verification
# RESEND_API_KEY        — transactional emails
