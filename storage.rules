rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAllowedType() {
      return request.resource.contentType.matches('image/.*')
        || request.resource.contentType == 'application/pdf'
        || request.resource.contentType == 'text/csv';
    }
    function isUnderLimit() {
      return request.resource.size < 10 * 1024 * 1024; // 10 MB
    }

    // Proof vault uploads, namespaced per user.
    match /users/{uid}/proof/{itemId}/{filename} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) && isAllowedType() && isUnderLimit();
    }

    // Default deny.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
