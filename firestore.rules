rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function ownsProject(projectId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/projects/$(projectId)).data.user_id == request.auth.uid;
    }

    // users/{uid} — server-managed.
    // Plan, stripe_*, onboarding flags, subscription_status are server-only.
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;

      // Daily AI usage counters — server-only.
      match /ai_usage/{day} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // Rate-limit window — server-only.
      match /rate_limits/{key} {
        allow read, write: if false;
      }
    }

    // Projects + nested phase data — owner-only, by user_id field.
    // Phase completion + ready_to_surface are server-only flips (callables).
    match /projects/{projectId} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.user_id == request.auth.uid
        && request.resource.data.current_phase == 1
        && request.resource.data.phase_1_completed == false
        && request.resource.data.phase_2_completed == false
        && request.resource.data.phase_3_completed == false
        && request.resource.data.phase_4_completed == false
        && request.resource.data.ready_to_surface == false;
      allow update: if isSignedIn()
        && resource.data.user_id == request.auth.uid
        // Phase flags + ready_to_surface + status transition to 'surfaced' are server-only.
        && request.resource.data.phase_1_completed == resource.data.phase_1_completed
        && request.resource.data.phase_2_completed == resource.data.phase_2_completed
        && request.resource.data.phase_3_completed == resource.data.phase_3_completed
        && request.resource.data.phase_4_completed == resource.data.phase_4_completed
        && request.resource.data.ready_to_surface == resource.data.ready_to_surface
        && request.resource.data.user_id == resource.data.user_id;
      allow delete: if isSignedIn() && resource.data.user_id == request.auth.uid;

      // Phase data the user edits directly.
      match /ghost_identity/{docId} {
        allow read, create, update, delete: if ownsProject(projectId);
      }
      match /silent_test/{docId} {
        allow read, create, update, delete: if ownsProject(projectId);
      }
      match /iteration_loop/{docId} {
        allow read, create, update, delete: if ownsProject(projectId);
      }
      match /lock_in/{docId} {
        allow read, create, update, delete: if ownsProject(projectId);
      }
      match /outreach_log/{docId} {
        allow read, create, update, delete: if ownsProject(projectId);
      }
      match /iteration_versions/{docId} {
        // version_number + flags are server-stamped in the trigger.
        allow read, create, update, delete: if ownsProject(projectId);
      }

      // Server-managed subcollections — readable by owner, writable only by server.
      match /insights/{docId}              { allow read: if ownsProject(projectId); allow write: if false; }
      match /generations/{docId}           { allow read: if ownsProject(projectId); allow write: if false; }
      match /audience_language/{docId}     { allow read: if ownsProject(projectId); allow write: if false; }
      match /objection_library/{docId}     { allow read: if ownsProject(projectId); allow write: if false; }
      match /competitive_gap/{docId}       { allow read: if ownsProject(projectId); allow write: if false; }
      match /iteration_suggestions/{docId} { allow read, update: if ownsProject(projectId); allow create, delete: if false; }
      match /outreach_templates/{docId}    { allow read, delete: if ownsProject(projectId); allow create, update: if false; }
      match /proof_package/{docId}         { allow read: if ownsProject(projectId); allow write: if false; }
    }

    // Proof vault — owner-only. file_url + storage_path written server-side via onFinalize.
    match /proof_vault/{itemId} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == resource.data.user_id
        && request.resource.data.storage_path == resource.data.storage_path
        && request.resource.data.file_url == resource.data.file_url;
      allow delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    // Activity log — server-written, user reads their own.
    match /activity_log/{entryId} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow write: if false;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
